# ============================================================
# AI Security Alert Triage Assistant — Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets!
# ============================================================

# ─── ANTHROPIC AI SETTINGS ─────────────────────────────────
# Get your API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR-API-KEY-HERE
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1

# ─── WAZUH API SETTINGS ────────────────────────────────────
# Full URL of your Wazuh manager (include https://)
WAZUH_HOST=https://YOUR-WAZUH-IP-HERE
WAZUH_PORT=55000
WAZUH_USER=triage-reader
WAZUH_PASSWORD=YOUR-WAZUH-API-PASSWORD
# Set to true if using a valid SSL certificate in production
WAZUH_VERIFY_SSL=false

# ─── POLLING SETTINGS ──────────────────────────────────────
POLL_INTERVAL=60
ALERT_LIMIT=10
# Wazuh alert levels: 1-3=low, 4-6=medium, 7-11=high, 12-15=critical
MIN_ALERT_LEVEL=7

# ─── OUTPUT SETTINGS ───────────────────────────────────────
REPORT_OUTPUT_DIR=reports/
GENERATE_PDF=true

# ─── LOGGING ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/triage.log
